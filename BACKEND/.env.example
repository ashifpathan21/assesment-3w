# Server Port
PORT=3001

# MongoDB Connection String (e.g., local MongoDB or MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/assessment

# JSON Web Token Secret Key
JWT_SECRET=your_jwt_secret_key_here

# Frontend Application Origin (used for CORS settings)
FRONTEND_URI=http://localhost:5173

# Cloudinary Credentials for image/media uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
